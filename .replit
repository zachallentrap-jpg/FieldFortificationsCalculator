# Replit config for SAP-1. The app is a fully static, offline-capable PWA (zero backend, zero
# external requests); Vite builds it to dist/, and dist/sap1.html is a single-file air-gapped copy.
#
# Deployment target = "autoscale": Replit's "Publish app" flow wants a persistent run command, so
# a tiny ZERO-DEPENDENCY static server (scripts/serve.js, Node built-ins only) serves dist/ on
# $PORT. This adds no runtime dependency and makes no outbound calls — the offline invariant is
# intact. If you prefer the leaner path, a static deployment also works: set deploymentTarget =
# "static" + publicDir = "dist" and drop the [deployment] run line (created via the Deployments
# tool → Static, not the app-publish flow).
run = "npm run dev -- --host 0.0.0.0 --port 5000"
entrypoint = "src/ui/index.html"
modules = ["nodejs-20"]

[nix]
channel = "stable-24_05"

[deployment]
deploymentTarget = "autoscale"
build = ["sh", "-c", "npm ci && npm run build"]
run = ["sh", "-c", "npm run start"]

[[ports]]
localPort = 5000
externalPort = 80
